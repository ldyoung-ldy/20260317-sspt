DATABASE_URL="YOUR_NEON_DATABASE_URL_HERE"
# 可选：本地 E2E 专用测试库，连接串名称必须包含 test 或 e2e。
# 若设置该值，bun run e2e:reset 与 bun run test:e2e 都会改用该库，
# 不会触碰开发库 DATABASE_URL；不设置时 E2E 工具会回退到 DATABASE_URL（仍受 test/e2e 名称保护）。
# 例：YOUR_NEON_TEST_BRANCH_URL_HERE（库名包含 test 或 e2e）
E2E_DATABASE_URL=""
AUTH_SECRET="YOUR_AUTH_SECRET_HERE"
ADMIN_EMAILS="YOUR_ADMIN_EMAIL_HERE"

AUTH_GITHUB_ID="YOUR_GITHUB_CLIENT_ID_HERE"
AUTH_GITHUB_SECRET="YOUR_GITHUB_CLIENT_SECRET_HERE"

AUTH_GOOGLE_ID="YOUR_GOOGLE_CLIENT_ID_HERE"
AUTH_GOOGLE_SECRET="YOUR_GOOGLE_CLIENT_SECRET_HERE"
